# PRO DATA AI CONTENT OS
# Environment Configuration

# AI Configuration
# Claude (DEFAULT) - recommended for brand voice and long-form content
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-7
AI_PROVIDER=claude

# OpenAI (ALTERNATIVE)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Application Settings
DEBUG=true
APP_NAME="PRO DATA AI CONTENT OS"
APP_VERSION=1.0.0

# Database
DATABASE_URL=sqlite:///./prod_data_os.db

# CORS (for frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000