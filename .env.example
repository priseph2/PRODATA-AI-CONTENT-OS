# ===========================================
# PRO DATA AI CONTENT OS
# Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE (Required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# AI PROVIDERS (At least one required)
# ===========================================
# OpenAI - Alternative provider
OPENAI_API_KEY=sk-your-openai-key

# Claude - Default provider
CLAUDE_API_KEY=sk-ant-api03-your-claude-key

# Which AI to use (options: "openai" or "claude")
AI_PROVIDER=claude

# ===========================================
# N8N AUTOMATION (Optional - app works in demo mode without)
# ===========================================
N8N_WEBHOOK_URL=https://your-n8n-instance.cloud/webhook
N8N_API_KEY=your-n8n-api-key

# ===========================================
# IMAGE GENERATION (Optional - v1.1)
# ===========================================
BANNERBEAR_API_KEY=your-bannerbear-key
CREATOMATE_API_KEY=your-creatomate-key
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# ===========================================
# APP SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# ===========================================
# SOCIAL MEDIA API KEYS (Optional - v1.1)
# ===========================================
# Meta (Facebook/Instagram)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# X (Twitter)
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret

# TikTok
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ===========================================
# NOTES
# ===========================================
# 1. Never commit .env or .env.local to git
# 2. For production, set these in Vercel dashboard
# 3. Supabase anon key is safe to expose to client
# 4. Service role key should only be used server-side
# 5. Claude is default - set AI_PROVIDER=openai to switch